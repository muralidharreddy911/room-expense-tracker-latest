{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Expense Tracker: Debug Local Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "./node_modules/tsx/dist/cli.mjs",
        "server/index.ts"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "NODE_ENV": "development",
        "PORT": "5000"
      },
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "smartStep": true
    }
  ]
}
